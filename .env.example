# Environment Configuration
NODE_ENV=production

# Database Configuration
# For Docker: /app/data/database.sqlite
# For local development: ./data/database.sqlite
DB_FILE_NAME=./data/database.sqlite

# Optional: Custom port (default: 3000)
# PORT=3000

# Optional: Host binding (default: 0.0.0.0 in production)
# HOST=0.0.0.0